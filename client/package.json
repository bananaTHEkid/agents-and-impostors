{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e:dev",
    "test:unit": "vitest",
    "test:e2e": "cross-env START_SERVER=true playwright test",
    "test:e2e:dev": "playwright test",
    "test:e2e:dev:with-server": "cross-env START_SERVER=true playwright test",
    "test:e2e:watch": "cross-env START_SERVER=true playwright test --watch",
    "playwright:install": "npx playwright install --with-deps",
    "test:e2e:prod": "E2E_ENV=production playwright test",
    "test:e2e:ci": "cross-env CI=true START_SERVER=true playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.3",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^5.1.0",
    "vitest": "^1.2.2"
  },
  "resolutions": {
    "@types/react": "^18.2.55",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0"
  }
}
