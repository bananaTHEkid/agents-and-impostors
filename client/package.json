{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e:dev",
    "test:unit": "vitest",
    "test:e2e": "cross-env START_SERVER=true playwright test",
    "test:e2e:dev": "playwright test",
    "test:e2e:dev:with-server": "cross-env START_SERVER=true playwright test",
    "test:e2e:watch": "cross-env START_SERVER=true playwright test --watch",
    "playwright:install": "npx playwright install --with-deps",
    "test:e2e:prod": "E2E_ENV=production playwright test",
    "test:e2e:ci": "cross-env CI=true START_SERVER=true playwright test",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21",
    "vitest": "^1.6.1",
    "storybook": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/addon-onboarding": "^10.2.14",
    "eslint-plugin-storybook": "^10.2.14",
    "playwright": "^1.58.2",
    "@vitest/browser": "^1.6.1",
    "@vitest/coverage-v8": "^1.6.1"
  },
  "resolutions": {
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1"
  }
}
